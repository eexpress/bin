<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="eexpss-theme" name="eexpss Theme" version="1.0">
  <color name="bg" value="#1a1a1a"/>
  <color name="fg" value="#e0e0e0"/>
  <color name="keyword" value="#8be9fd"/>
  <color name="identifier" value="#f8f8f2"/>
  <color name="string" value="#f1fa8c"/>
  <color name="comment" value="#6272a4"/>

  <style name="def:background" background="#1a1a1a"/>
  <style name="def:normal" foreground="#e0e0e0"/>
  <style name="def:keyword" foreground="#8be9fd" bold="true"/>
  <style name="def:identifier" foreground="#f8f8f2"/>
  <style name="def:string" foreground="#f1fa8c"/>
  <style name="def:comment" foreground="#6272a4" italic="true"/>
</style-scheme>
